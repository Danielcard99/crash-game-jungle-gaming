{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "strictNullChecks": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["bun-types"],
    "baseUrl": "./"
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}